# Variables del conector jira (prefijo RUVIC_JIRA_)
# Copia como .env. NUNCA subas el .env al repositorio.

# Obligatorias
RUVIC_JIRA_BASE_URL=https://miempresa.atlassian.net
RUVIC_JIRA_EMAIL=usuario@empresa.com
RUVIC_JIRA_API_TOKEN=ATATT3xFfGF0-REEMPLAZA-CON-TU-TOKEN

# Opcional: proyecto por defecto para crear/buscar tickets
RUVIC_JIRA_DEFAULT_PROJECT=OPS

# Opcional: timeout HTTP en segundos (default 20)
RUVIC_JIRA_TIMEOUT=20
