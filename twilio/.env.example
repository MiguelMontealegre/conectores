# Variables del conector twilio_sms (prefijo RUVIC_TWILIO_SMS_)
# Copia como .env, usa UNO de los dos modos de credenciales.
# NUNCA subas el .env al repositorio.

RUVIC_TWILIO_SMS_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Modo A: Auth Token ────────────────────────────────────────────────
RUVIC_TWILIO_SMS_AUTH_TOKEN=REEMPLAZA_CON_TU_AUTH_TOKEN

# ── Modo B: API Key (recomendado producción) ──────────────────────────
#RUVIC_TWILIO_SMS_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#RUVIC_TWILIO_SMS_API_KEY_SECRET=REEMPLAZA_CON_TU_API_KEY_SECRET

# ── Remitente: uno de los dos ─────────────────────────────────────────
RUVIC_TWILIO_SMS_FROM_NUMBER=+15017122661
#RUVIC_TWILIO_SMS_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

RUVIC_TWILIO_SMS_TIMEOUT=15
