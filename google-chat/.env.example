# Variables del conector gchat (prefijo RUVIC_GCHAT_)
# Copia este archivo como .env y usa SOLO UNO de los dos modos.
# NUNCA subas el .env al repositorio.

# ── Modo A: webhook entrante (un espacio) ─────────────────────────────
# Espacio → Apps e integraciones → Webhooks → Añadir webhook. URL completa:
RUVIC_GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=REEMPLAZA&token=REEMPLAZA

# ── Modo B: cuenta de servicio (Chat API) ─────────────────────────────
# Pega el JSON completo en UNA línea, o carga con:
#   export RUVIC_GCHAT_SERVICE_ACCOUNT_JSON="$(cat credenciales.json)"
#RUVIC_GCHAT_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
#RUVIC_GCHAT_DEFAULT_SPACE=spaces/AAAAAAAAAAA

# Opcional: timeout HTTP en segundos (default 15)
RUVIC_GCHAT_TIMEOUT=15
