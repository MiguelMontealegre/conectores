# Variables del conector aranda (prefijo RUVIC_ARANDA_)
# Copia como .env. NUNCA subas el .env al repositorio.

# Obligatoria: token de integración (JWT). Con o sin el prefijo "Bearer "
RUVIC_ARANDA_TOKEN=Bearer eyJ0eXAiOiJKV1Q-REEMPLAZA-CON-TU-TOKEN

# Opcional: URL base de la API v9 (por defecto la nube de Arandasoft)
RUVIC_ARANDA_BASE_URL=https://proyectos.arandasoft.com/asmsapi/api/v9

# Opcional: validar certificado TLS (false para instalaciones con cert interno)
RUVIC_ARANDA_VERIFY_SSL=false

# Opcional: timeout HTTP en segundos (default 30)
RUVIC_ARANDA_TIMEOUT=30
