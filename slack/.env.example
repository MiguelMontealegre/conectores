# Variables del conector slack (prefijo RUVIC_SLACK_)
# Copia como .env. NUNCA subas el .env al repositorio.

# Obligatoria: Bot User OAuth Token de la app de Slack (empieza por xoxb-)
RUVIC_SLACK_BOT_TOKEN=xoxb-REEMPLAZA-CON-TU-TOKEN

# Opcional: destino por defecto. Acepta #canal, ID de canal (C…) o ID de usuario (U…)
RUVIC_SLACK_DEFAULT_CHANNEL=#general

# Opcional: timeout HTTP en segundos (default 15)
RUVIC_SLACK_TIMEOUT=15
